# ─────────────────────────────────────────
#  IssuePilot — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o          # or gpt-4-turbo

# GitHub
GITHUB_TOKEN=ghp_...         # needs: repo, issues, pull_requests scopes
GITHUB_USERNAME=your-username

# Agent behaviour
MAX_RETRIES=3                # how many times to retry on test failure
WORKSPACE_DIR=/tmp/issuepilot-workspace

# Docker sandbox (must match a valid image with python + pip)
DOCKER_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=60
